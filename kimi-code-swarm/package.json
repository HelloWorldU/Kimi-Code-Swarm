{
  "name": "kimi-code-swarm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:engine": "npm --prefix agent-engine run build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:engine": "npm --prefix agent-engine run typecheck",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "analyze": "npx tsx ../ast/analyzer.ts src tests",
    "check-docs": "npx tsx ../ci/scripts/check-docs-sync.ts",
    "check-test": "npx tsx ../ci/scripts/check-test-sync.ts --base origin/main",
    "health-check": "npx tsx ../scripts/health-check.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run typecheck:engine && npm run lint && npm run analyze && npm run check-docs && npm run test && npm run build",
    "postinstall": "node ../scripts/setup-hooks.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.11.0",
    "@types/dompurify": "^3.0.5",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "dompurify": "^3.4.7",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "vue": "^3.5.33",
    "zod": "^4.4.3"
  }
}
