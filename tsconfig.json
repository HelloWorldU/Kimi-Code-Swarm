{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@vue/compiler-sfc": ["./kimi-code-swarm/node_modules/@vue/compiler-sfc"]
    }
  },
  "include": [
    "ast/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "kimi-code-swarm/node_modules"
  ]
}
